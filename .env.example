# Copy this to .env.local and fill in your values.
# Add these same variables to your Vercel project settings.
# Do NOT commit real secrets or real phone numbers — keep this file placeholders only.

# Shared password that gates the app and its API routes (required).
APP_PASSWORD=choose_a_strong_password

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: override the model (defaults to claude-sonnet-4-6).
ANTHROPIC_MODEL=claude-sonnet-4-6

# Meta WhatsApp Business API
META_WHATSAPP_TOKEN=your_permanent_meta_system_user_token_here
META_PHONE_NUMBER_ID=your_meta_phone_number_id_here
WHATSAPP_TEMPLATE_NAME=the_peak_monthly_report

# Comma-separated WhatsApp numbers in international format, e.g. +96800000000,+96811111111
OWNER_NUMBERS=
